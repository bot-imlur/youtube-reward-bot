# Bot Connection Details
# Discord bot token from Discord Developer Portal
BOT_TOKEN=

# Discord Application Client ID
CLIENT_ID=

# Discord Server (Guild) ID where commands are registered
GUILD_ID=

# YouTube Data API v3 Key
YOUTUBE_API_KEY=

# Administrative Privileges
# Discord user ID of the admin who can run /admin-* commands
ADMIN_USER_ID=

# Global Channel Restriction
# Comma-separated channel IDs where bot commands are allowed (empty = all channels)
GLOBAL_ALLOWED_CHANNELS=

# GTA-VC Game Channel Restriction
# Comma-separated channel IDs for GTA-VC claims (must be subset of GLOBAL_ALLOWED_CHANNELS)
GTA_VC_ALLOWED_CHANNELS=

# ─── YouTube OAuth2 (Comment Reply Feature) ────────────────────────────────
# Required only for auto-replying to YouTube comments after a successful reward.
# Obtain these from GCP Console → APIs & Services → Credentials → OAuth 2.0 Client.
# Run `node scripts/generateOAuthToken.js` once to generate the refresh token.

# OAuth2 Client ID from GCP Console
YOUTUBE_CLIENT_ID=

# OAuth2 Client Secret from GCP Console
YOUTUBE_CLIENT_SECRET=

# Refresh token generated by scripts/generateOAuthToken.js (one-time)
# Never commit this value to version control.
YOUTUBE_REFRESH_TOKEN=

# ─── Cloudflare R2 (Signed URL Rewards) ─────────────────────────────────────
# Cloudflare Account ID — found in the right sidebar of the Cloudflare Dashboard
R2_ACCOUNT_ID=

# R2 API Token credentials — R2 → Manage R2 API Tokens → Create Account API Token
# Set permission: Object Read, scoped to your bucket only
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Name of the R2 bucket holding the game files (e.g. imlur-games)
R2_BUCKET_NAME=

# ─── Cloudflare Worker (Download Gateway) ──────────────────────────────────
# Shared secret between this bot and the Cloudflare Worker.
# Generate any long random string (e.g. openssl rand -hex 32).
# Must ALSO be set in Cloudflare via: npx wrangler secret put WORKER_SECRET
WORKER_SECRET=

# Domain where the Cloudflare Worker is deployed (default: files.imlur.com)
WORKER_DOMAIN=files.imlur.com
